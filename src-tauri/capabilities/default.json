{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "dialog:allow-open",
    "dialog:allow-save",
    "core:tray:default",
    "core:tray:allow-new",
    "core:tray:allow-set-tooltip",
    "core:tray:allow-set-icon",
    "core:tray:allow-set-menu"
  ]
}
